# ORACULO/UDESC — Variáveis de ambiente
# Copie este arquivo para .env e ajuste os valores:
#   cp .env.example .env

# ── PostgreSQL ──────────────────────────────────────────────
PGHOST=localhost
PGPORT=5432
PGDATABASE=oraculo_udesc
PGUSER=oraculo
PGPASSWORD=oraculo_pass

# ── Ollama ──────────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434

# ── ORACULO ─────────────────────────────────────────────────
ORACULO_INGESTION_DIR=./ingestion/pdfs
ORACULO_LOG_LEVEL=INFO
